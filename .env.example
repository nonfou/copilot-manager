# ─── 管理员初始化（首次启动必填）─────────────────────────────────────────────
# 初始化完成后可移除或保留（不会被二次使用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# ─── 静态加密（推荐启用）──────────────────────────────────────────────────────
# 用于加密 github_token 和 API Key 等敏感字段
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 或：openssl rand -hex 32
# 警告：一旦启用并写入数据后，不可更改或丢失此密钥，否则数据无法解密！
ENCRYPTION_KEY=60a797703b3007e14cffb29faa9212a909cd092994d595c432033cec2b14345f

# ─── CORS 白名单（可选）───────────────────────────────────────────────────────
# 允许跨域的来源列表，多个用逗号分隔
# 不设置则允许所有跨域（适合本地开发）；生产环境建议明确指定
# CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com

# ─── 代理限流（可选）──────────────────────────────────────────────────────────
# 每个 API Key 每分钟最大请求数，0 = 不限流
# RATE_LIMIT_PER_MINUTE=300

# ─── 服务端口 ─────────────────────────────────────────────────────────────────
# PORT=4242
